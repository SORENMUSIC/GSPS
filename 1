<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PeachState Property Solutions | Real Estate Investment</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --brand-blue: #1a365d;
            --brand-peach: #f97316; 
        }
        .bg-brand-blue { background-color: var(--brand-blue); }
        .text-brand-blue { color: var(--brand-blue); }
        .bg-brand-peach { background-color: var(--brand-peach); }
        .hover-brand-peach:hover { background-color: #ea580c; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans">

    <!-- Header -->
    <header class="fixed w-full z-50 bg-white/90 backdrop-blur-md shadow-sm">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <div class="flex items-center space-x-2">
                <div class="w-10 h-10 bg-brand-blue rounded-lg flex items-center justify-center text-white shadow-lg">
                    <i class="fas fa-house-chimney text-xl"></i>
                </div>
                <div>
                    <span class="font-bold text-xl tracking-tight text-brand-blue block leading-none">PeachState</span>
                    <span class="text-xs font-bold uppercase tracking-widest text-orange-600">Property Solutions</span>
                </div>
            </div>
            
            <nav class="hidden md:flex items-center space-x-8 font-semibold text-sm">
                <a href="#" class="hover:text-orange-600 transition">Home</a>
                <a href="#about" class="hover:text-orange-600 transition">Our Story</a>
                <a href="#how-it-works" class="hover:text-orange-600 transition">Process</a>
                <a href="#submit" class="bg-brand-blue text-white px-6 py-2.5 rounded-full hover:bg-blue-900 transition shadow-md">Submit Property</a>
            </nav>
            
            <button class="md:hidden text-brand-blue text-2xl" onclick="document.getElementById('mobileMenu').classList.toggle('hidden')">
                <i class="fas fa-bars"></i>
            </button>
        </div>
        
        <div id="mobileMenu" class="hidden bg-white border-t md:hidden flex flex-col p-6 space-y-4 shadow-xl">
            <a href="#" class="font-bold text-lg">Home</a>
            <a href="#about" class="font-bold text-lg">Our Story</a>
            <a href="#how-it-works" class="font-bold text-lg">Process</a>
            <a href="#submit" class="font-bold text-lg text-orange-600">Submit Property</a>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 md:pt-48 md:pb-32 bg-brand-blue text-white overflow-hidden">
        <div class="absolute top-0 right-0 w-1/3 h-full bg-orange-500/10 skew-x-12 transform translate-x-20"></div>
        <div class="container mx-auto px-4 relative z-10">
            <div class="max-w-3xl">
                <h1 class="text-4xl md:text-6xl font-black mb-6 leading-tight">
                    Sell Your Property <span class="text-orange-400">Fast</span>. <br>Connect with Top Investors.
                </h1>
                <p class="text-xl text-blue-100 mb-10 leading-relaxed">
                    Based in Georgia, we bridge the gap between motivated sellers and a nationwide network of active investors. Professional, fair, and family-oriented.
                </p>
                <div class="flex flex-wrap gap-4">
                    <a href="#submit" class="bg-brand-peach text-white text-lg font-bold px-10 py-4 rounded-xl shadow-2xl hover-brand-peach transition transform hover:-translate-y-1">
                        Get Started Now
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="py-24 bg-white">
        <div class="container mx-auto px-4">
            <div class="grid md:grid-cols-2 gap-16 items-center">
                <div class="order-2 md:order-1">
                    <div class="inline-block px-4 py-1 bg-orange-100 text-orange-700 rounded-full text-sm font-bold mb-4 uppercase tracking-widest">
                        About Our Company
                    </div>
                    <h2 class="text-3xl md:text-4xl font-bold text-brand-blue mb-6 leading-snug">Our Roots in Georgia, Our Reach Nationwide</h2>
                    <p class="text-lg text-slate-600 mb-6 leading-relaxed">
                        Founded by <strong>J Davis</strong>, PeachState Property Solutions originated in the heart of Georgia, with strong ties to <strong>Warner Robins (Houston County)</strong> and <strong>Albany</strong>. As a real estate investment company, our core focus is connecting motivated property sellers with investors looking for their next opportunity.
                    </p>
                    <p class="text-lg text-slate-600 mb-8 leading-relaxed">
                        We are a rapidly growing team built on a foundation of hard work and mutual growth. What sets us apart is our <strong>unique company culture</strong>—we keep our environment positive, supportive, and treat every member of our team like family.
                    </p>
                    <div class="p-6 bg-slate-50 border-l-4 border-brand-peach rounded-r-xl italic text-slate-700">
                        "We don't just close deals; we build relationships and help our community move forward." — J Davis, Owner
                    </div>
                </div>
                <div class="order-1 md:order-2 grid grid-cols-2 gap-4">
                    <div class="space-y-4">
                        <div class="h-48 bg-slate-200 rounded-2xl flex items-center justify-center overflow-hidden shadow-md">
                            <i class="fas fa-users text-5xl text-slate-400"></i>
                        </div>
                        <div class="h-64 bg-brand-blue rounded-2xl p-8 text-white flex flex-col justify-end">
                            <span class="text-4xl font-bold mb-2">100%</span>
                            <span class="text-sm uppercase tracking-widest opacity-80 font-bold">Family Culture</span>
                        </div>
                    </div>
                    <div class="space-y-4 pt-8">
                        <div class="h-64 bg-orange-500 rounded-2xl p-8 text-white flex flex-col justify-end">
                            <i class="fas fa-location-dot text-3xl mb-4"></i>
                            <span class="text-xl font-bold">Warner Robins & Albany, GA</span>
                        </div>
                        <div class="h-48 bg-slate-200 rounded-2xl flex items-center justify-center overflow-hidden shadow-md">
                            <i class="fas fa-handshake text-5xl text-slate-400"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Process Section -->
    <section id="how-it-works" class="py-24 bg-slate-50">
        <div class="container mx-auto px-4">
            <div class="text-center max-w-2xl mx-auto mb-16">
                <h2 class="text-3xl md:text-4xl font-bold text-brand-blue mb-4">Simple 4-Step Process</h2>
                <p class="text-slate-600">We make selling your property a stress-free experience from start to finish.</p>
            </div>
            
            <div class="grid md:grid-cols-4 gap-8">
                <div class="relative p-8 bg-white rounded-2xl shadow-sm text-center">
                    <div class="w-14 h-14 bg-brand-blue text-white rounded-xl flex items-center justify-center text-2xl font-bold mx-auto mb-6 shadow-lg">1</div>
                    <h3 class="font-bold text-xl mb-3">Submit</h3>
                    <p class="text-sm text-slate-500">Provide your property details using our secure form below.</p>
                </div>
                <div class="relative p-8 bg-white rounded-2xl shadow-sm text-center">
                    <div class="w-14 h-14 bg-orange-500 text-white rounded-xl flex items-center justify-center text-2xl font-bold mx-auto mb-6 shadow-lg">2</div>
                    <h3 class="font-bold text-xl mb-3">Review</h3>
                    <p class="text-sm text-slate-500">J Davis and the team analyze the data and market potential.</p>
                </div>
                <div class="relative p-8 bg-white rounded-2xl shadow-sm text-center">
                    <div class="w-14 h-14 bg-brand-blue text-white rounded-xl flex items-center justify-center text-2xl font-bold mx-auto mb-6 shadow-lg">3</div>
                    <h3 class="font-bold text-xl mb-3">Contact</h3>
                    <p class="text-sm text-slate-500">We reach out with a fair offer or professional consultation.</p>
                </div>
                <div class="relative p-8 bg-white rounded-2xl shadow-sm text-center">
                    <div class="w-14 h-14 bg-orange-500 text-white rounded-xl flex items-center justify-center text-2xl font-bold mx-auto mb-6 shadow-lg">4</div>
                    <h3 class="font-bold text-xl mb-3">Close</h3>
                    <p class="text-sm text-slate-500">We connect with investors and finalize the deal on your timeline.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Form Section -->
    <section id="submit" class="py-24 bg-brand-blue relative">
        <div class="container mx-auto px-4 max-w-4xl">
            <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">
                <div class="bg-slate-50 px-8 py-10 border-b text-center">
                    <h2 class="text-3xl font-bold text-brand-blue">Property Submission Form</h2>
                    <p class="text-slate-600 mt-2 italic">Fast, private, and professional review.</p>
                </div>
                
                <!-- Main Form -->
                <form id="propertyForm" action="https://formsubmit.co/sorennmedia@gmail.com" method="POST" class="p-8 md:p-12 space-y-8">
                    <!-- FormSubmit Hidden Config -->
                    <input type="hidden" name="_subject" value="URGENT: New Property Lead - PeachState">
                    <input type="hidden" name="_template" value="table">
                    
                    <div class="grid md:grid-cols-2 gap-8">
                        <!-- Left Column -->
                        <div class="space-y-5">
                            <h4 class="font-black text-brand-blue uppercase text-xs tracking-widest border-b pb-2">Owner Info</h4>
                            <div>
                                <label class="block text-sm font-bold mb-1.5">Full Name *</label>
                                <input type="text" name="FullName" id="fullName" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none transition">
                            </div>
                            <div>
                                <label class="block text-sm font-bold mb-1.5">Phone Number *</label>
                                <input type="tel" name="Phone" id="phone" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none transition">
                            </div>
                            <div>
                                <label class="block text-sm font-bold mb-1.5">Email Address *</label>
                                <input type="email" name="Email" id="email" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none transition">
                            </div>
                        </div>

                        <!-- Right Column -->
                        <div class="space-y-5">
                            <h4 class="font-black text-brand-blue uppercase text-xs tracking-widest border-b pb-2">Property Details</h4>
                            <div>
                                <label class="block text-sm font-bold mb-1.5">Property Address *</label>
                                <input type="text" name="Address" id="address" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none transition">
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-bold mb-1.5">City *</label>
                                    <input type="text" name="City" id="city" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none transition">
                                </div>
                                <div>
                                    <label class="block text-sm font-bold mb-1.5">Zip Code *</label>
                                    <input type="text" name="Zip" id="zip" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none transition">
                                </div>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-bold mb-1.5">Beds</label>
                                    <input type="number" name="Beds" id="beds" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl outline-none">
                                </div>
                                <div>
                                    <label class="block text-sm font-bold mb-1.5">Baths</label>
                                    <input type="number" step="0.5" name="Baths" id="baths" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl outline-none">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="grid md:grid-cols-2 gap-8">
                        <div class="space-y-4">
                            <label class="block text-sm font-bold">Property Condition</label>
                            <select name="Condition" id="condition" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl outline-none">
                                <option>Good</option>
                                <option>Needs Repairs</option>
                                <option>Major Repairs</option>
                            </select>
                        </div>
                        <div class="space-y-4">
                            <label class="block text-sm font-bold">Timeline to Sell</label>
                            <select name="Timeline" id="timeline" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl outline-none">
                                <option>Immediately</option>
                                <option>1-3 Months</option>
                                <option>3+ Months</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold mb-1.5">Describe Property & Repairs Needed</label>
                        <textarea name="Details" id="details" rows="4" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-orange-500" placeholder="Please provide any details that would help us..."></textarea>
                    </div>

                    <div class="flex flex-col gap-4">
                        <button type="submit" class="w-full bg-brand-peach text-white text-xl font-black py-5 rounded-2xl shadow-xl hover-brand-peach transition-all transform hover:scale-[1.01]">
                            Submit for Instant Review
                        </button>
                        
                        <div class="flex items-center justify-center space-x-4 py-2">
                            <span class="h-px bg-slate-200 flex-grow"></span>
                            <span class="text-xs font-bold text-slate-400 uppercase tracking-tighter">OR USE MANUAL EMAIL</span>
                            <span class="h-px bg-slate-200 flex-grow"></span>
                        </div>

                        <button type="button" onclick="manualEmail()" class="w-full bg-slate-100 text-brand-blue font-bold py-4 rounded-2xl border border-slate-200 hover:bg-slate-200 transition-all flex items-center justify-center gap-2">
                            <i class="fas fa-envelope-open-text"></i>
                            Draft Email (Auto-Fill)
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-slate-900 text-white pt-20 pb-10">
        <div class="container mx-auto px-4">
            <div class="grid md:grid-cols-3 gap-12 mb-16">
                <div>
                    <h4 class="text-xl font-bold mb-6">PeachState Property</h4>
                    <p class="text-slate-400 leading-relaxed">Connecting Georgia homeowners with reliable real estate investors. Proudly serving Warner Robins, Albany, and beyond.</p>
                </div>
                <div>
                    <h4 class="text-xl font-bold mb-6">Quick Links</h4>
                    <ul class="space-y-3 text-slate-400">
                        <li><a href="#" class="hover:text-orange-500">Home</a></li>
                        <li><a href="#about" class="hover:text-orange-500">About J Davis</a></li>
                        <li><a href="#how-it-works" class="hover:text-orange-500">How It Works</a></li>
                        <li><a href="#submit" class="hover:text-orange-500">Sell Now</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-xl font-bold mb-6">Contact Us</h4>
                    <p class="text-slate-400 mb-2"><strong>Email:</strong> sorennmedia@gmail.com</p>
                    <p class="text-slate-400 italic">Origin: Houston County, Georgia</p>
                </div>
            </div>
            <div class="border-t border-slate-800 pt-10 text-center text-slate-500 text-sm">
                &copy; 2024 PeachState Property Solutions. All rights reserved.
            </div>
        </div>
    </footer>

    <script>
        function manualEmail() {
            // Get form values
            const name = document.getElementById('fullName').value || '[No Name]';
            const phone = document.getElementById('phone').value || '[No Phone]';
            const email = document.getElementById('email').value || '[No Email]';
            const address = document.getElementById('address').value || '[No Address]';
            const city = document.getElementById('city').value || '[No City]';
            const zip = document.getElementById('zip').value || '[No Zip]';
            const beds = document.getElementById('beds').value || 'N/A';
            const baths = document.getElementById('baths').value || 'N/A';
            const condition = document.getElementById('condition').value;
            const timeline = document.getElementById('timeline').value;
            const details = document.getElementById('details').value || 'None provided';

            const subject = encodeURIComponent("Property Inquiry: " + address);
            const body = encodeURIComponent(
                "Property Details for PeachState Property Solutions:\n\n" +
                "OWNER: " + name + "\n" +
                "PHONE: " + phone + "\n" +
                "EMAIL: " + email + "\n" +
                "ADDRESS: " + address + ", " + city + " " + zip + "\n\n" +
                "SPECS: " + beds + " Bed / " + baths + " Bath\n" +
                "CONDITION: " + condition + "\n" +
                "TIMELINE: " + timeline + "\n\n" +
                "REPAIR DETAILS:\n" + details
            );

            window.location.href = `mailto:sorennmedia@gmail.com?subject=${subject}&body=${body}`;
        }
    </script>
</body>
</html>

